# ─────────────────────────────────────────────────────────────────────────────
#  Miljövariabler – Gröna Byggnader offert-/signeringsflöde
# ─────────────────────────────────────────────────────────────────────────────
#  Kopiera denna fil till `.env.local` (gitignoreras) för lokal utveckling och sätt
#  motsvarande värden i Netlify under Site settings -> Environment variables.
#  Lägg ALDRIG riktiga nycklar i git. service_role-nyckeln får ENDAST finnas i
#  serverns miljö – aldrig i klientkod eller i en NEXT_PUBLIC_-variabel.
# ─────────────────────────────────────────────────────────────────────────────

# — Supabase ——————————————————————————————————————————————————————————————————
# Project URL + anon-nyckel (Supabase -> Project Settings -> API). Säkra att
# exponera i webbläsaren (anon-nyckeln skyddas av RLS).
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service_role-nyckel (Supabase -> Project Settings -> API). HEMLIG – kringgår RLS.
# Används ENDAST i serverkod (Route Handlers / Server Components / middleware).
SUPABASE_SERVICE_ROLE_KEY=

# — Resend (e-post) ————————————————————————————————————————————————————————————
RESEND_API_KEY=
# Avsändaradress. Kräver en verifierad domän i Resend för utskick till externa
# mottagare. Under test kan "Gröna Byggnader <onboarding@resend.dev>" användas
# (når då bara din egen Resend-kontoadress).
RESEND_FROM="Gröna Byggnader <offert@gronabyggnader.se>"
# Intern adress som får notis när en ny förfrågan kommer in.
ADMIN_NOTIFY_EMAIL=info@gronabyggnader.se

# — App ————————————————————————————————————————————————————————————————————————
# Publik bas-URL, används för länkar i mejl (t.ex. signeringslänken).
# Lokalt:     http://localhost:3000
# Produktion: https://gronabyggnader-stockholm.netlify.app
APP_BASE_URL=http://localhost:3000

# — Spamskydd (förberett, valfritt) ———————————————————————————————————————————
# Cloudflare Turnstile för publika formulär. Lämna tomt för att stänga av.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
